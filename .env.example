PORT=3005
NODE_ENV=development

# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ms_lead_capture
DB_USERNAME=root
DB_PASSWORD=

# Facebook / Meta
META_APP_SECRET=tu_app_secret_aqui
META_APP_TOKEN=tu_app_token_aqui
META_VERIFY_TOKEN=cereza_meta_verify
META_GRAPH_VERSION=v22.0

# Timeouts HTTP (ms)
GRAPH_TIMEOUT_MS=8000
OPP_TIMEOUT_MS=10000

# Servicios internos
SOCIALCC_INTERNAL_URL=http://ms_socialcc:3000/api/socialcc
OPPORTUNITIES_INTERNAL_URL=http://ms_opportunities:3000/api/opportunities

# Token monitor
TOKEN_WARNING_DAYS=10
TOKEN_CHECK_CRON=0 8 * * *

# Webhook
WEBHOOK_CONCURRENCY=5

# Limpieza de logs
LOG_RETAIN_DAYS=90
LOG_CLEANUP_CRON=0 3 * * 0

# Multi-pod: solo el pod con CRON_MASTER=true ejecuta los jobs cron
CRON_MASTER=true

# CORS — dominios permitidos separados por coma (usar * solo en dev)
ALLOWED_ORIGINS=https://app.cerezacc.com,https://admin.cerezacc.com

# Socialcc timeout (ms)
SOCIALCC_TIMEOUT_MS=8000
